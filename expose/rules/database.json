    "severity": "HIGH"
  },
  {
    "name": "Postgres URI",
    "pattern": "postgres(?:ql)?://[^ \\n]+",
    "severity": "HIGH"
  },
  {
    "name": "MySQL URI",
    "pattern": "mysql://[^ \\n]+",
    "severity": "HIGH"
  }
